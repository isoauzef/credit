// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Homepage form submissions (quote form) ──────────────────────────

// ── Admin user (email + password login) ─────────────────────────────
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model ContactSubmission {
  id                          Int      @id @default(autoincrement())
  name                        String   @db.VarChar(255)
  firstName                   String?  @db.VarChar(128)
  lastName                    String?  @db.VarChar(128)
  email                       String   @db.VarChar(255)
  phone                       String?  @db.VarChar(50)
  companyName                 String?  @db.VarChar(255)
  companyAddress              String?  @db.VarChar(255)
  businessLocations           String?  @db.VarChar(128)
  platform                    String?  @db.VarChar(128)
  negativeReviewsNeedRemoving String?  @db.VarChar(128)
  budgetPerRemoval            String?  @db.VarChar(128)
  source                      String?  @db.VarChar(64)
  metadata                    Json?
  createdAt                   DateTime @default(now())

  @@map("contact_submissions")
}

// ── Checkout form submissions with Stripe status ────────────────────
model CheckoutSubmission {
  id                    Int       @id @default(autoincrement())
  name                  String    @db.VarChar(255)
  email                 String    @db.VarChar(255)
  phone                 String?   @db.VarChar(50)
  companyName           String?   @db.VarChar(255)
  googleDataId          String?   @db.VarChar(255)
  reviewLinks           Json?
  reason                String?   @db.Text
  quantity              Int       @default(1)
  amount                Int       @default(0) // cents
  // Credit repair intake (Step 1)
  address               String?   @db.VarChar(500)
  dob                   String?   @db.VarChar(20) // YYYY-MM-DD
  ssnLast4              String?   @db.VarChar(4)
  ssnEncrypted          String?   @db.Text // legacy full-SSN ciphertext; new checkout stores last 4 only
  // Document uploads (Step 2) — relative paths under private-uploads/
  idDocPath             String?   @db.VarChar(500)
  utilityDocPath        String?   @db.VarChar(500)
  creditReportDocPath   String?   @db.VarChar(500)
  // Auth-letter signature (Step 3)
  signatureDataUrl      String?   @db.LongText // image/png data URL
  signedAt              DateTime?
  authLetterSnapshot    String?   @db.Text // rendered auth letter text at sign time
  // Stripe + status
  stripeSessionId       String?   @db.VarChar(255)
  stripePaymentIntentId String?   @db.VarChar(255)
  stripeCustomerId      String?   @db.VarChar(255)
  stripeSetupIntentId   String?   @db.VarChar(255)
  stripePaymentMethodId String?   @db.VarChar(255)
  crmLeadId             Int?
  paymentStatus         String    @default("pending") @db.VarChar(32) // pending | card_saved | charged | canceled | failed
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  clientDashboardAccount ClientDashboardAccount?

  @@map("checkout_submissions")
}

model ClientDashboardAccount {
  id                   Int                @id @default(autoincrement())
  checkoutSubmissionId Int                @unique
  checkoutSubmission   CheckoutSubmission @relation(fields: [checkoutSubmissionId], references: [id], onDelete: Cascade)
  email                String             @db.VarChar(255)
  passwordHash         String             @db.VarChar(255)
  status               String             @default("active") @db.VarChar(32)
  lastLoginAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  bureauReports ClientBureauReport[]
  documents     ClientDashboardDocument[]
  updates       ClientDashboardUpdate[]

  @@index([email])
  @@map("client_dashboard_accounts")
}

model ClientBureauReport {
  id               Int                    @id @default(autoincrement())
  accountId        Int
  account          ClientDashboardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  bureau           String                 @db.VarChar(32)
  score            Int                    @default(0)
  scoreDate        DateTime?
  negativeItems    Int                    @default(0)
  disputes         Int                    @default(0)
  deletions        Int                    @default(0)
  positivesNote    String?                @db.Text
  dateGenerated    DateTime?
  accountSummary   Json?
  creditUsage      Json?
  debtSummary      Json?
  reportDocPath    String?                @db.VarChar(500)
  reportOriginalName String?              @db.VarChar(255)
  reportUploadedAt DateTime?
  reportParsedAt   DateTime?
  reportParseStatus String?               @db.VarChar(32)
  reportParseError String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([accountId, bureau])
  @@map("client_bureau_reports")
}

model ClientDashboardDocument {
  id           Int                    @id @default(autoincrement())
  accountId    Int
  account      ClientDashboardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type         String                 @db.VarChar(64)
  label        String                 @db.VarChar(128)
  token        String                 @db.VarChar(500)
  originalName String?                @db.VarChar(255)
  mimeType     String?                @db.VarChar(100)
  size         Int?
  uploadedBy   String                 @default("client") @db.VarChar(32)
  createdAt    DateTime               @default(now())

  @@index([accountId, type])
  @@map("client_dashboard_documents")
}

model ClientDashboardUpdate {
  id        Int                    @id @default(autoincrement())
  accountId Int
  account   ClientDashboardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title     String                 @db.VarChar(160)
  body      String                 @db.Text
  createdBy String                 @default("Zack") @db.VarChar(128)
  disputes  Int?
  deletions Int?
  createdAt DateTime               @default(now())

  @@index([accountId, createdAt])
  @@map("client_dashboard_updates")
}

// ── Email templates (quote-autoresponse, checkout-success) ──────────
model EmailTemplate {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  subject     String   @db.VarChar(500)
  previewText String?  @db.VarChar(500)
  content     Json // full template data (same structure as template-data.json)
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

// ── Key-value settings (stripe, smtp, site, email toggles) ──────────
model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(128)
  value     String   @db.Text
  group     String   @db.VarChar(32) // stripe | smtp | site | email
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── CMS page content (per page + section) ───────────────────────────
model PageContent {
  id        Int      @id @default(autoincrement())
  page      String   @db.VarChar(64) // homepage | checkout
  section   String   @db.VarChar(64) // hero | features | faq | ...
  content   Json
  updatedAt DateTime @updatedAt

  @@unique([page, section])
  @@map("page_content")
}

model BlogPost {
  id               Int       @id @default(autoincrement())
  title            String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(255)
  excerpt          String?   @db.Text
  contentHtml      String    @db.LongText
  featuredImageUrl String?   @db.VarChar(1000)
  featuredImageAlt String?   @db.VarChar(255)
  status           String    @default("draft") @db.VarChar(32)
  metaTitle        String?   @db.VarChar(255)
  metaDescription  String?   @db.VarChar(500)
  ogTitle          String?   @db.VarChar(255)
  ogDescription    String?   @db.VarChar(500)
  ogImageUrl       String?   @db.VarChar(1000)
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, publishedAt])
  @@map("blog_posts")
}
